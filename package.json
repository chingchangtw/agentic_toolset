{
  "name": "agentic-toolset",
  "version": "0.1.0",
  "description": "A development toolset for hosting AI agent skills, plugins, and MCP artifacts",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
     "release": "node scripts/generate-manifest.mjs && node scripts/build-release.mjs"
  },
  "keywords": [
    "ai",
    "agents",
    "skills",
    "plugins",
    "mcp"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {}
}
